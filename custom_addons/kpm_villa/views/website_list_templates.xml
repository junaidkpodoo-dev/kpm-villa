<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Mobile Rooms List -->
    <template id="villa_mobile_rooms" name="Rooms List">
        <t t-call="kpm_villa.villa_mobile_layout">
            <style>
                .villa-rooms-header {
                background: linear-gradient(145deg, #101917 0%, #18302b 58%, #27483f 100%);
                border-radius: 0 0 28px 28px;
                padding: 24px 20px 30px;
                color: #fff8ed;
                box-shadow: 0 18px 34px rgba(16, 25, 23, .24);
                }

                .villa-rooms-header .rooms-back {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: rgba(169, 197, 179, .16);
                border: 1px solid rgba(169, 197, 179, .30);
                display: flex;
                align-items: center;
                justify-content: center;
                color: #d6eadc;
                text-decoration: none;
                }

                .villa-rooms-title {
                color: #fff8ed;
                font-size: 26px;
                line-height: 1.1;
                }

                .villa-rooms-subtitle {
                color: rgba(255,248,237,.68);
                font-size: 13px;
                }

                .villa-room-accent {
                color: #2f6b59;
                }

                .villa-room-selected {
                border: 1px solid #7aa893;
                box-shadow: 0 12px 28px rgba(16, 25, 23, .08);
                }
            </style>

            <div class="app-header villa-rooms-header d-flex align-items-center">
                <a href="/villa/mobile/dashboard" class="rooms-back me-3"><i class="fa fa-chevron-left"/></a>
                <div>
                    <h4 class="villa-rooms-title mb-1 fw-bold">Rooms</h4>
                    <p class="villa-rooms-subtitle mb-0">Occupancy and availability</p>
                </div>
            </div>
            <div class="container pb-5">
                <div class="row g-3 mb-4 animate-up">
                    <div class="col-4">
                        <a href="/villa/mobile/rooms" t-attf-class="mobile-card h-100 mb-0 text-center d-block text-decoration-none #{'villa-room-selected' if selected_status == 'all' else ''}">
                            <span class="card-label">Total</span>
                            <div class="card-value villa-room-accent"><t t-esc="summary['total']"/></div>
                        </a>
                    </div>
                    <div class="col-4">
                        <a href="/villa/mobile/rooms?status=occupied" t-attf-class="mobile-card h-100 mb-0 text-center d-block text-decoration-none #{'border border-danger' if selected_status == 'occupied' else ''}">
                            <span class="card-label">Occupied</span>
                            <div class="card-value text-danger"><t t-esc="summary['occupied']"/></div>
                        </a>
                    </div>
                    <div class="col-4">
                        <a href="/villa/mobile/rooms?status=available" t-attf-class="mobile-card h-100 mb-0 text-center d-block text-decoration-none #{'border border-success' if selected_status == 'available' else ''}">
                            <span class="card-label">Available</span>
                            <div class="card-value text-success"><t t-esc="summary['available']"/></div>
                        </a>
                    </div>
                </div>

                <t t-foreach="rooms" t-as="room">
                    <a t-att-href="'/villa/mobile/room/%s' % room.id" class="mobile-card animate-up d-block text-decoration-none text-reset">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div t-attf-class="p-3 rounded-4 me-3 #{'bg-success-light text-success' if room.status == 'available' else 'bg-danger-light text-danger' if room.status == 'occupied' else 'bg-warning-light text-warning'}">
                                    <i class="fa fa-bed fa-lg"/>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold"><t t-esc="room.name"/></h6>
                                    <p class="text-muted small mb-0">
                                        <t t-esc="dict(room._fields['villa_type'].selection).get(room.villa_type)"/>
                                        <t t-if="room.floor"> - <t t-esc="dict(room._fields['floor'].selection).get(room.floor)"/></t>
                                    </p>
                                </div>
                            </div>
                            <span t-attf-class="badge #{'bg-success-light text-success' if room.status == 'available' else 'bg-danger-light text-danger' if room.status == 'occupied' else 'bg-warning-light text-warning'}">
                                <t t-esc="dict(room._fields['status'].selection).get(room.status)"/>
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <span class="small text-muted">Rent</span>
                            <span class="fw-bold villa-room-accent">
                                <t t-esc="room.monthly_rent" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                            </span>
                        </div>
                    </a>
                </t>

                <t t-if="not rooms">
                    <p class="text-center text-muted py-3 mb-0 small">No rooms found.</p>
                </t>
            </div>
        </t>
    </template>

    <!-- Mobile Room Detail -->
    <template id="villa_mobile_room_detail" name="Room Detail">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/rooms" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Room Details</h4>
            </div>
            <div class="container pb-5">
                <div class="mobile-card animate-up">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 p-4 rounded-4 me-3 text-primary">
                                <i class="fa fa-bed fa-2x"/>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0"><t t-esc="room.name"/></h5>
                                <p class="text-muted mb-0"><t t-esc="dict(room._fields['villa_type'].selection).get(room.villa_type)"/></p>
                            </div>
                        </div>
                        <span t-attf-class="badge #{'bg-success-light text-success' if room.status == 'available' else 'bg-danger-light text-danger' if room.status == 'occupied' else 'bg-warning-light text-warning'}">
                            <t t-esc="dict(room._fields['status'].selection).get(room.status)"/>
                        </span>
                    </div>

                    <div class="list-item-mobile">
                        <span class="text-muted">Floor</span>
                        <span class="fw-bold"><t t-esc="dict(room._fields['floor'].selection).get(room.floor)"/></span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Monthly Rent</span>
                        <span class="fw-bold text-primary"><t t-esc="room.monthly_rent" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Agreements</span>
                        <span class="fw-bold"><t t-esc="room.agreement_count"/></span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Total Revenue</span>
                        <span class="fw-bold text-success"><t t-esc="room.total_revenue" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                    </div>
                </div>

                <t t-if="active_agreement">
                    <div class="mobile-card animate-up" style="animation-delay: 0.1s;">
                        <h6 class="fw-bold mb-3 d-flex align-items-center">
                            <i class="fa fa-file-text-o me-2 text-info"/> Current Tenant
                        </h6>
                        <div class="list-item-mobile">
                            <span class="text-muted">Tenant</span>
                            <span class="fw-bold"><t t-esc="active_agreement.partner_id.name"/></span>
                        </div>
                        <div class="list-item-mobile">
                            <span class="text-muted">Agreement</span>
                            <a t-att-href="'/villa/mobile/agreement/%s' % active_agreement.id" class="fw-bold text-primary text-decoration-none">
                                <t t-esc="active_agreement.name"/>
                            </a>
                        </div>
                        <div class="list-item-mobile">
                            <span class="text-muted">Start Date</span>
                            <span class="fw-bold"><t t-esc="active_agreement.start_date"/></span>
                        </div>
                        <div class="list-item-mobile">
                            <span class="text-muted">End Date</span>
                            <span class="fw-bold"><t t-esc="active_agreement.end_date"/></span>
                        </div>
                    </div>
                </t>

                <t t-if="room.description">
                    <div class="mobile-card animate-up" style="animation-delay: 0.2s;">
                        <h6 class="fw-bold mb-2">Description</h6>
                        <p class="text-muted small mb-0"><t t-esc="room.description"/></p>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <!-- Mobile Customers List -->
    <template id="villa_mobile_customers" name="Customers List">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/dashboard" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Customers</h4>
            </div>
            <div class="container pb-5">
                <form action="/villa/mobile/customers" method="get" class="mobile-card animate-up mb-3">
                    <div class="input-group">
                        <input type="search" name="q" class="form-control border-0 bg-light" placeholder="Search customers" t-att-value="search_term"/>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-search"/>
                        </button>
                    </div>
                </form>

                <div class="d-flex justify-content-end mb-3">
                    <a href="/villa/mobile/customer/new" class="btn btn-success rounded-pill px-4 fw-bold">
                        <i class="fa fa-plus me-1"/> Add Customer
                    </a>
                </div>

                <t t-foreach="customers" t-as="customer">
                    <a t-att-href="'/villa/mobile/customer/%s' % customer.id" class="mobile-card animate-up d-block text-decoration-none text-reset">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center min-w-0">
                                <img t-if="customer.image_128" t-att-src="image_data_uri(customer.image_128)" class="rounded-circle me-3 flex-shrink-0" style="width:56px;height:56px;object-fit:cover;"/>
                                <div t-else="" class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width:56px;height:56px;">
                                    <i class="fa fa-user fa-lg"/>
                                </div>
                                <div class="min-w-0">
                                    <h6 class="mb-1 fw-bold text-truncate"><t t-esc="customer.name"/></h6>
                                    <p class="text-muted small mb-0 text-truncate">
                                        <i class="fa fa-phone me-1"/>
                                        <t t-esc="customer.mobile or customer.phone or '-'"/>
                                    </p>
                                    <p class="text-muted smaller mb-0 text-truncate">
                                        <i class="fa fa-map-marker me-1"/>
                                        <t t-esc="customer.city or customer.state_id.name or customer.country_id.name or '-'"/>
                                    </p>
                                </div>
                            </div>
                            <i class="fa fa-chevron-right text-muted ms-3"/>
                        </div>
                    </a>
                </t>
                <t t-if="not customers">
                    <p class="text-center text-muted py-3 mb-0 small">No customers found.</p>
                </t>
            </div>
        </t>
    </template>

    <!-- Mobile Customer Form -->
    <template id="villa_mobile_customer_form" name="New Customer">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/customers" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Add Customer</h4>
            </div>
            <div class="container pb-5">
                <div class="mobile-card animate-up">
                    <form action="/villa/mobile/customer/save" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="card-label">Name</label>
                            <input type="text" name="name" class="form-control border-0 bg-light" required="required"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Mobile</label>
                            <input type="tel" name="mobile" class="form-control border-0 bg-light"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Phone</label>
                            <input type="tel" name="phone" class="form-control border-0 bg-light"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Email</label>
                            <input type="email" name="email" class="form-control border-0 bg-light"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Street</label>
                            <input type="text" name="street" class="form-control border-0 bg-light"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Street 2</label>
                            <input type="text" name="street2" class="form-control border-0 bg-light"/>
                        </div>
                        <div class="mb-4">
                            <label class="card-label">Place</label>
                            <input type="text" name="city" class="form-control border-0 bg-light"/>
                        </div>
                        <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold border-0">
                            Save Customer
                        </button>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- Mobile Customer Detail -->
    <template id="villa_mobile_customer_detail" name="Customer Detail">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/customers" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Customer Details</h4>
            </div>
            <div class="container pb-5">
                <div class="mobile-card animate-up text-center">
                    <img t-if="customer.image_1920" t-att-src="image_data_uri(customer.image_1920)" class="rounded-circle mb-3" style="width:96px;height:96px;object-fit:cover;"/>
                    <div t-else="" class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center mx-auto mb-3" style="width:96px;height:96px;">
                        <i class="fa fa-user fa-2x"/>
                    </div>
                    <h5 class="fw-bold mb-1"><t t-esc="customer.name"/></h5>
                    <p class="text-muted mb-0"><t t-esc="customer.city or customer.state_id.name or customer.country_id.name or 'No place set'"/></p>
                </div>

                <div class="mobile-card animate-up" style="animation-delay: 0.1s;">
                    <h6 class="fw-bold mb-3 d-flex align-items-center">
                        <i class="fa fa-address-card-o me-2 text-info"/> Basic Details
                    </h6>
                    <div class="list-item-mobile">
                        <span class="text-muted">Mobile</span>
                        <span class="fw-bold"><t t-esc="customer.mobile or '-'"/></span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Phone</span>
                        <span class="fw-bold"><t t-esc="customer.phone or '-'"/></span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Email</span>
                        <span class="fw-bold text-break"><t t-esc="customer.email or '-'"/></span>
                    </div>
                    <div class="list-item-mobile align-items-start">
                        <span class="text-muted">Address</span>
                        <span class="fw-bold text-end">
                            <t t-esc="customer.street or ''"/>
                            <t t-if="customer.street2"><br/><t t-esc="customer.street2"/></t>
                            <t t-if="customer.city"><br/><t t-esc="customer.city"/></t>
                            <t t-if="customer.state_id"><br/><t t-esc="customer.state_id.name"/></t>
                            <t t-if="customer.country_id"><br/><t t-esc="customer.country_id.name"/></t>
                            <t t-if="not (customer.street or customer.street2 or customer.city or customer.state_id or customer.country_id)">-</t>
                        </span>
                    </div>
                </div>

                <t t-if="agreements">
                    <div class="mobile-card animate-up" style="animation-delay: 0.2s;">
                        <h6 class="fw-bold mb-3 d-flex align-items-center">
                            <i class="fa fa-file-text-o me-2 text-primary"/> Agreements
                        </h6>
                        <t t-foreach="agreements" t-as="agreement">
                            <div class="list-item-mobile">
                                <div>
                                    <span class="fw-bold small d-block"><t t-esc="agreement.villa_id.name"/></span>
                                    <span class="text-muted smaller"><t t-esc="agreement.name"/></span>
                                </div>
                                <a t-att-href="'/villa/mobile/agreement/%s' % agreement.id" class="text-primary fw-bold small text-decoration-none">View</a>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <!-- Mobile Agreements List -->
    <template id="villa_mobile_agreements" name="Agreements List">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/dashboard" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Rent Agreements</h4>
            </div>
            <div class="container pb-5">
                <t t-foreach="agreements" t-as="agreement">
                    <div class="mobile-card animate-up">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-3 rounded-4 me-3 text-primary">
                                    <i class="fa fa-file-text-o fa-lg"/>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold"><t t-esc="agreement.villa_id.name"/></h6>
                                    <p class="text-muted small mb-0"><t t-esc="agreement.partner_id.name"/></p>
                                </div>
                            </div>
                            <span t-attf-class="badge #{'bg-success-light' if agreement.state == 'running' else 'bg-warning-light'}"><t t-esc="agreement.state"/></span>
                        </div>
                        <div class="mt-3 d-flex justify-content-between align-items-center pt-2 border-top">
                            <span class="small text-muted"><i class="fa fa-calendar me-1"/> <t t-esc="agreement.start_date"/></span>
                            <a t-att-href="'/villa/mobile/agreement/%s' % agreement.id" class="text-primary small text-decoration-none fw-bold">View Details <i class="fa fa-chevron-right ms-1 small"/></a>
                        </div>
                    </div>
                </t>
            </div>
            <a href="/villa/mobile/agreement/new" class="fab">
                <i class="fa fa-plus"/>
            </a>
        </t>
    </template>

    <!-- Mobile Expenses List -->
    <template id="villa_mobile_expenses" name="Expenses List">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center" style="background: linear-gradient(135deg, var(--app-secondary) 0%, #fb7185 100%);">
                <a href="/villa/mobile/dashboard" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Maintenance Fixes</h4>
            </div>
            <div class="container pb-5">
                <form action="/villa/mobile/expenses" method="get" class="mobile-card animate-up mb-3">
                    <div class="input-group">
                        <input type="search" name="q" class="form-control border-0 bg-light" placeholder="Search fixes..." t-att-value="search_term"/>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa fa-search"/>
                        </button>
                    </div>
                </form>

                <t t-foreach="expenses" t-as="expense">
                    <div class="mobile-card animate-up">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-danger-light p-3 rounded-4 me-3 text-danger">
                                    <i class="fa fa-wrench fa-lg"/>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold"><t t-esc="expense.name"/></h6>
                                    <p class="text-muted small mb-0"><t t-esc="expense.villa_id.name"/></p>
                                </div>
                            </div>
                            <div class="text-end">
                                <p class="mb-0 fw-bold text-danger"><t t-esc="expense.amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></p>
                                <p class="mb-0 text-muted smaller text-uppercase"><t t-esc="expense.expense_type"/></p>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
            <a href="/villa/mobile/expense/new" class="fab" style="background: var(--app-secondary);">
                <i class="fa fa-plus"/>
            </a>
        </t>
    </template>

    <!-- Mobile Water Bill List -->
    <template id="villa_mobile_water_bills" name="Water Bills List">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%);">
                <a href="/villa/mobile/dashboard" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Water Split Bills</h4>
            </div>
            <div class="container pb-5">
                <form action="/villa/mobile/water_bills" method="get" class="mobile-card animate-up mb-3">
                    <div class="input-group">
                        <input type="search" name="q" class="form-control border-0 bg-light" placeholder="Search water bills..." t-att-value="search_term"/>
                        <button type="submit" class="btn btn-info text-white">
                            <i class="fa fa-search"/>
                        </button>
                    </div>
                </form>

                <div class="mobile-card animate-up mb-3" style="background: linear-gradient(135deg, rgba(14, 165, 233, 0.12) 0%, rgba(56, 189, 248, 0.08) 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">New water bill</h6>
                            <p class="text-muted small mb-0">Create a bill and split it across running rooms.</p>
                        </div>
                        <a href="/villa/mobile/water_bill/new" class="btn btn-info rounded-circle d-flex align-items-center justify-content-center text-white flex-shrink-0" style="width:44px;height:44px;">
                            <i class="fa fa-plus"/>
                        </a>
                    </div>
                </div>

                <t t-foreach="bills" t-as="bill">
                    <a t-att-href="'/villa/mobile/water_bill/%s' % bill.id" class="mobile-card animate-up d-block text-decoration-none text-reset">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-info-light p-3 rounded-4 me-3 text-info">
                                    <i class="fa fa-tint fa-lg"/>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold"><t t-esc="bill.name"/></h6>
                                    <p class="text-muted small mb-0"><t t-esc="bill.bill_date"/></p>
                                </div>
                            </div>
                            <div class="text-end">
                                <p class="mb-0 fw-bold text-info">
                                    <t t-esc="bill.total_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                </p>
                                <p class="mb-0 smaller fw-bold text-danger">
                                    Due:
                                    <t t-esc="sum(bill.line_ids.mapped('due_amount'))" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                </p>
                                <p class="mb-0 text-muted smaller text-uppercase"><t t-esc="dict(bill._fields['split_method'].selection).get(bill.split_method)"/></p>
                            </div>
                        </div>
                    </a>
                </t>
            </div>
            <a href="/villa/mobile/water_bill/new" class="fab" style="background: var(--app-info);">
                <i class="fa fa-plus"/>
            </a>
        </t>
    </template>

    <!-- Mobile Water Bill Form -->
    <template id="villa_mobile_water_bill_form" name="New Water Bill">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%);">
                <a href="/villa/mobile/water_bills" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Add Water Bill</h4>
            </div>
            <div class="container pb-5">
                <div class="mobile-card animate-up border-0" style="background: linear-gradient(135deg, rgba(14, 165, 233, 0.12) 0%, rgba(240, 249, 255, 1) 100%);">
                    <div class="d-flex align-items-center">
                        <div class="bg-info-light text-info p-3 rounded-4 me-3">
                            <i class="fa fa-tint fa-lg"/>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Water split bill</h6>
                            <p class="text-muted small mb-0">Equal split will create dues for all running agreements.</p>
                        </div>
                    </div>
                </div>

                <div class="mobile-card animate-up" style="animation-delay: 0.1s;">
                    <form action="/villa/mobile/water_bill/save" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3">
                            <label class="card-label">Bill Reference</label>
                            <input type="text" name="name" class="form-control border-0 bg-light" placeholder="e.g. WATER/2026/05" required="required"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Bill Date</label>
                            <input type="date" name="bill_date" class="form-control border-0 bg-light" t-att-value="datetime.date.today()" required="required"/>
                        </div>
                        <div class="mb-3">
                            <label class="card-label">Total Amount</label>
                            <input type="number" name="total_amount" class="form-control border-0 bg-light" step="0.01" min="0" required="required"/>
                        </div>
                        <div class="mb-4">
                            <label class="card-label">Split Method</label>
                            <div class="d-flex gap-3 mb-3">
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="split_method" id="split_equal" value="equal" checked="checked" autocomplete="off"/>
                                    <label class="btn btn-outline-info w-100 rounded-4 py-3" for="split_equal">
                                        <i class="fa fa-balance-scale d-block mb-1 fa-lg"/>
                                        Equal Split
                                    </label>
                                </div>
                                <div class="flex-fill">
                                    <input type="radio" class="btn-check" name="split_method" id="split_manual" value="manual" autocomplete="off"/>
                                    <label class="btn btn-outline-info w-100 rounded-4 py-3" for="split_manual">
                                        <i class="fa fa-pencil-square-o d-block mb-1 fa-lg"/>
                                        Manual Split
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div id="manual_split_section" class="d-none animate-up mb-4">
                            <label class="card-label">Manual Split Amounts</label>
                            <div class="bg-light rounded-4 p-3">
                                <t t-foreach="running_rents" t-as="rent">
                                    <div class="mb-3 last-child-mb-0">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small fw-bold"><t t-esc="rent.villa_id.name"/></span>
                                            <span class="text-muted smaller"><t t-esc="rent.partner_id.name"/></span>
                                        </div>
                                        <div class="input-group">
                                            <span class="input-group-text border-0 bg-white"><t t-esc="res_company.currency_id.symbol"/></span>
                                            <input type="number" t-attf-name="rent_amount_#{rent.id}" class="form-control border-0" step="0.01" min="0" placeholder="0.00"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <script>
                            document.addEventListener('DOMContentLoaded', function() {
                                const manualSection = document.getElementById('manual_split_section');
                                const radios = document.querySelectorAll('input[name="split_method"]');
                                
                                radios.forEach(radio => {
                                    radio.addEventListener('change', function() {
                                        if (this.value === 'manual') {
                                            manualSection.classList.remove('d-none');
                                        } else {
                                            manualSection.classList.add('d-none');
                                        }
                                    });
                                });
                            });
                        </script>
                        <button type="submit" class="btn btn-info w-100 rounded-pill py-3 fw-bold border-0 text-white" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%);">
                            Save Water Bill
                        </button>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- Mobile Expense Form -->
    <template id="villa_mobile_expense_form" name="New Expense">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center" style="background: linear-gradient(135deg, var(--app-secondary) 0%, #fb7185 100%);">
                <a href="/villa/mobile/expenses" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Report a Fix</h4>
            </div>
            <div class="container">
                <div class="mobile-card animate-up">
                    <form action="/villa/mobile/expense/save" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        
                        <div class="mb-3">
                            <label class="card-label">Description</label>
                            <input type="text" name="name" class="form-control border-0 bg-light" placeholder="e.g. Broken Pipe" required="required"/>
                        </div>

                        <div class="mb-3">
                            <label class="card-label">Villa</label>
                            <select name="villa_id" class="form-select border-0 bg-light" required="required">
                                <t t-foreach="villas" t-as="v">
                                    <option t-att-value="v.id"><t t-esc="v.name"/></option>
                                </t>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="card-label">Expense Type</label>
                            <select name="expense_type" class="form-select border-0 bg-light">
                                <option value="plumbing">Plumbing</option>
                                <option value="electrical">Electrical</option>
                                <option value="maintenance">Maintenance</option>
                                <option value="cleaning">Cleaning</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="card-label">Amount</label>
                            <input type="number" name="amount" class="form-control border-0 bg-light" required="required" step="0.01"/>
                        </div>

                        <div class="mb-4">
                            <label class="card-label">Date</label>
                            <input type="date" name="expense_date" class="form-control border-0 bg-light" t-att-value="datetime.date.today()" required="required"/>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-3 fw-bold shadow-lg border-0" style="background: linear-gradient(135deg, var(--app-secondary) 0%, #fb7185 100%);">Save Maintenance Fix</button>
                    </form>
                </div>
            </div>
        </t>
    </template>
    <!-- Mobile Water Bill Detail -->
    <template id="villa_mobile_water_bill_detail" name="Water Bill Detail">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%);">
                <a href="/villa/mobile/water_bills" class="text-white me-3"><i class="fa fa-chevron-left"/></a>
                <h4 class="mb-0 fw-bold">Bill Details</h4>
            </div>
            <div class="container pb-5">
                <div class="mobile-card animate-up mb-4" style="background: linear-gradient(135deg, rgba(14, 165, 233, 0.1) 0%, rgba(255, 255, 255, 1) 100%);">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-info-light text-info p-3 rounded-4 me-3">
                                <i class="fa fa-tint fa-2x"/>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0"><t t-esc="bill.name"/></h5>
                                <p class="text-muted mb-0"><t t-esc="bill.bill_date"/></p>
                            </div>
                        </div>
                        <span class="badge bg-info-light text-info"><t t-esc="dict(bill._fields['split_method'].selection).get(bill.split_method)"/></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-light">
                        <span class="text-muted fw-bold">Total Amount</span>
                        <span class="h4 mb-0 fw-bold text-info"><t t-esc="bill.total_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                    </div>
                </div>

                <h6 class="fw-bold px-2 mb-3">Split Details</h6>
                <t t-foreach="bill.line_ids" t-as="line">
                    <div class="mobile-card animate-up">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="mb-0 fw-bold"><t t-esc="line.villa_id.name"/></h6>
                                <p class="text-muted small mb-0"><t t-esc="line.rent_id.partner_id.name"/></p>
                            </div>
                            <span t-attf-class="badge #{'bg-success-light text-success' if line.due_amount == 0 else 'bg-warning-light text-warning'}">
                                <t t-if="line.due_amount == 0">Fully Paid</t>
                                <t t-else="">Due: <t t-esc="line.due_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></t>
                            </span>
                        </div>
                        
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="bg-light p-2 rounded-3 text-center">
                                    <span class="smaller text-muted d-block">Split Amount</span>
                                    <span class="small fw-bold"><t t-esc="line.amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light p-2 rounded-3 text-center">
                                    <span class="smaller text-muted d-block">Paid Amount</span>
                                    <span class="small fw-bold text-success"><t t-esc="line.paid_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                                </div>
                            </div>
                        </div>

                        <t t-if="line.due_amount > 0">
                            <button type="button" class="btn btn-info w-100 rounded-pill text-white fw-bold py-2 shadow-sm" 
                                    data-bs-toggle="modal" t-attf-data-bs-target="#paymentModal#{line.id}">
                                <i class="fa fa-money me-1"/> Add Payment
                            </button>

                            <!-- Payment Modal -->
                            <div class="modal fade" t-attf-id="paymentModal#{line.id}" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered mx-3">
                                    <div class="modal-content border-0 rounded-5 shadow-lg">
                                        <form t-attf-action="/villa/mobile/water_bill/line/#{line.id}/payment" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title fw-bold">Record Payment</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body py-4">
                                                <p class="text-muted small mb-4">Adding payment for <t t-esc="line.villa_id.name"/> water bill.</p>
                                                <div class="mb-3">
                                                    <label class="card-label">Payment Amount</label>
                                                    <div class="input-group">
                                                        <span class="input-group-text border-0 bg-light"><t t-esc="res_company.currency_id.symbol"/></span>
                                                        <input type="number" name="payment_amount" class="form-control border-0 bg-light" 
                                                               t-att-value="line.due_amount" step="0.01" t-att-max="line.due_amount" min="0.01" required="required"/>
                                                    </div>
                                                    <div class="form-text smaller text-info">Maximum: <t t-esc="line.due_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></div>
                                                </div>
                                            </div>
                                            <div class="modal-footer border-0 pt-0">
                                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-info text-white rounded-pill px-4 fw-bold">Confirm Payment</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>
