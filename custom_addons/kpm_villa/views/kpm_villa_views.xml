<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Villa Tree View -->
    <record id="view_kpm_villa_tree" model="ir.ui.view">
        <field name="name">kpm.villa.tree</field>
        <field name="model">kpm.villa</field>
        <field name="arch" type="xml">
            <list string="Villas">
                <field name="name"/>
                <field name="floor"/>
                <field name="villa_type"/>
                <field name="monthly_rent"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-info="status == 'occupied'" decoration-warning="status == 'maintenance'"/>
            </list>
        </field>
    </record>

    <!-- Villa Form View -->
    <record id="view_kpm_villa_form" model="ir.ui.view">
        <field name="name">kpm.villa.form</field>
        <field name="model">kpm.villa</field>
        <field name="arch" type="xml">
            <form string="Villa">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,occupied,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_agreements" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="agreement_count" widget="statinfo" string="Agreements"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Villa Name / Room No"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="floor"/>
                            <field name="villa_type"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="monthly_rent"/>
                            <field name="total_revenue" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Villa Kanban View -->
    <record id="view_kpm_villa_kanban" model="ir.ui.view">
        <field name="name">kpm.villa.kanban</field>
        <field name="model">kpm.villa</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="image" widget="image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <ul>
                                    <li>Type: <field name="villa_type"/></li>
                                    <li>Rent: <field name="monthly_rent"/></li>
                                </ul>
                                <div class="oe_kanban_bottom_right">
                                    <field name="status" widget="label_selection" options="{'classes': {'available': 'success', 'occupied': 'info', 'maintenance': 'warning'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Villa Search View -->
    <record id="view_kpm_villa_search" model="ir.ui.view">
        <field name="name">kpm.villa.search</field>
        <field name="model">kpm.villa</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="floor"/>
                <field name="villa_type"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="Occupied" name="occupied" domain="[('status', '=', 'occupied')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by': 'status'}"/>
                    <filter string="Floor" name="floor" context="{'group_by': 'floor'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kpm_villa" model="ir.actions.act_window">
        <field name="name">Villas</field>
        <field name="res_model">kpm.villa</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first villa!</p>
        </field>
    </record>
</odoo>
