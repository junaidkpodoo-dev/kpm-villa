<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_rent_agreement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2 class="text-center">RENT AGREEMENT</h2>
                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Tenant:</strong>
                                <p t-field="o.partner_id"/>
                            </div>
                            <div class="col-6">
                                <strong>Villa:</strong>
                                <p t-field="o.villa_id"/>
                            </div>
                        </div>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th class="text-right">Monthly Rent</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-field="o.start_date"/></td>
                                    <td><span t-field="o.end_date"/></td>
                                    <td class="text-right"><span t-field="o.monthly_rent"/></td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <h4 class="mt32">Payment Summary</h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Total Paid</th>
                                    <th>Pending Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-field="o.total_paid"/></td>
                                    <td><span t-field="o.pending_amount"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
