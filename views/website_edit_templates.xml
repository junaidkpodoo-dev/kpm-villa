<?xml version="1.0" encoding="utf-8"?>
<odoo>   <!-- Mobile Agreement Edit Form -->
    <template id="villa_mobile_agreement_edit" name="Edit Agreement">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center">
                <a href="/villa/mobile/dashboard" class="text-white me-3">
                    <i class="fa fa-chevron-left"/>
                </a>
                <h4 class="mb-0 fw-bold">
                    <t t-if="agreement">Edit Agreement</t>
                    <t t-else="">New Agreement</t>
                </h4>
            </div>

            <div class="container pb-5">
                <div class="mobile-card animate-up">
                    <form action="/villa/mobile/agreement/save" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="agreement_id" t-att-value="agreement.id if agreement else ''"/>

                        <div class="mb-3">
                            <label class="card-label">Villa</label>
                            <select name="villa_id" class="form-select border-0 bg-light" required="required">
                                <t t-foreach="villas" t-as="v">
                                    <option t-att-value="v.id"
                                            t-att-selected="agreement and agreement.villa_id.id == v.id">
                                        <t t-esc="v.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="card-label">Tenant</label>
                            <select name="partner_id" class="form-select border-0 bg-light" required="required">
                                <t t-foreach="partners" t-as="p">
                                    <option t-att-value="p.id"
                                            t-att-selected="agreement and agreement.partner_id.id == p.id">
                                        <t t-esc="p.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <div class="mb-3">
                                    <label class="card-label">Start Date</label>
                                    <input type="date" name="start_date" class="form-control border-0 bg-light"
                                           t-att-value="agreement.start_date if agreement else datetime.date.today()"
                                           required="required"/>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="mb-3">
                                    <label class="card-label">End Date</label>
                                    <input type="date" name="end_date" class="form-control border-0 bg-light"
                                           t-att-value="agreement.end_date if agreement else (datetime.date.today() + datetime.timedelta(days=365))"
                                           required="required"/>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="card-label">Monthly Rent</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light text-muted">
                                    <t t-esc="res_company.currency_id.symbol"/>
                                </span>
                                <input type="number" name="monthly_rent" class="form-control border-0 bg-light"
                                       t-att-value="agreement.monthly_rent if agreement else ''" required="required"
                                       step="0.01"/>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="card-label">Notes</label>
                            <textarea name="notes" class="form-control border-0 bg-light" rows="3"
                                      placeholder="Additional details...">
                                <t t-if="agreement" t-esc="agreement.notes"/>
                            </textarea>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-lg border-0 mb-3"
                                style="background: linear-gradient(135deg, var(--app-primary) 0%, var(--app-primary-light) 100%);">
                            <t t-if="agreement">Update Agreement</t>
                            <t t-else="">Create Agreement</t>
                        </button>

                        <t t-if="agreement">
                            <a t-attf-href="/villa/mobile/agreement/delete/#{agreement.id}"
                               class="btn btn-link w-100 text-danger text-decoration-none small fw-bold"
                               onclick="return confirm('Are you sure you want to delete this agreement?')">Delete
                                Agreement
                            </a>
                        </t>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>
