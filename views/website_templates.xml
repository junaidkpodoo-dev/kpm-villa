<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Base Layout for Mobile App Style -->
    <template id="villa_mobile_layout" name="Villa Mobile Layout">
        <t t-call="website.layout">
            <t t-set="head">
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;display=swap"
                      rel="stylesheet"/>
            </t>

            <div class="o_villa_app">
                <t t-out="0"/>

                <!-- Bottom Navigation -->
                <div class="app-bottom-nav">
                    <a href="/villa/mobile/dashboard" class="nav-item-mobile">
                        <i class="fa fa-th-large"/>
                        <span>Home</span>
                    </a>
                    <a href="/villa/mobile/rooms" class="nav-item-mobile">
                        <i class="fa fa-bed"/>
                        <span>Rooms</span>
                    </a>
                    <a href="/villa/mobile/customers" class="nav-item-mobile">
                        <i class="fa fa-users"/>
                        <span>Customers</span>
                    </a>
                    <a href="/villa/mobile/water_bills" class="nav-item-mobile">
                        <i class="fa fa-tint"/>
                        <span>Water</span>
                    </a>
                    <a href="/villa/mobile/expenses" class="nav-item-mobile">
                        <i class="fa fa-wrench"/>
                        <span>Fixes</span>
                    </a>
                </div>
            </div>
        </t>
    </template>

    <!-- Mobile Dashboard -->
    <template id="villa_mobile_dashboard" name="Mobile Dashboard">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0 fw-bold">KPM Villa</h4>
                        <p class="opacity-75 small mb-0">Management Overview</p>
                    </div>
                    <div class="rounded-circle bg-white bg-opacity-25 p-2 text-white border border-white border-opacity-25">
                        <i class="fa fa-bell-o"/>
                    </div>
                </div>
            </div>

            <div class="container pb-5">
                <!-- Main KPI Card -->
                <div class="mobile-card bg-primary text-white border-0 shadow-lg animate-up"
                     style="background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);">
                    <div class="row align-items-center">
                        <div class="col-7">
                            <span class="small opacity-75">Net Profit</span>
                            <h2 class="fw-bold mb-0">
                                <t t-esc="stats['net_profit']"
                                   t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                            </h2>
                        </div>
                        <div class="col-5 text-end">
                            <div class="d-inline-block p-3 rounded-circle bg-white bg-opacity-20">
                                <i class="fa fa-line-chart fa-2x"/>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top border-white border-opacity-10 d-flex justify-content-between">
                        <div>
                            <p class="small mb-0 opacity-75">Revenue</p>
                            <p class="fw-bold mb-0">
                                <t t-esc="stats['total_revenue']"
                                   t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                            </p>
                        </div>
                        <div class="text-end">
                            <p class="small mb-0 opacity-75">Expenses</p>
                            <p class="fw-bold mb-0 text-danger-light">-
                                <t t-esc="stats['total_expenses']"
                                   t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Secondary Stats -->
                <div class="row g-3 mb-4 animate-up" style="animation-delay: 0.1s;">
                    <div class="col-6">
                        <div class="mobile-card h-100 mb-0">
                            <div class="d-flex align-items-center mb-2">
                                <div class="p-2 rounded-circle bg-info-light text-info me-2">
                                    <i class="fa fa-home"/>
                                </div>
                                <span class="card-label mb-0">Occupancy</span>
                            </div>
                            <div class="card-value text-info">
                                <t t-esc="stats['occupied_villas']"/>
                                /
                                <t t-esc="stats['occupied_villas'] + stats['available_villas']"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mobile-card h-100 mb-0">
                            <div class="d-flex align-items-center mb-2">
                                <div class="p-2 rounded-circle bg-danger-light text-danger me-2">
                                    <i class="fa fa-clock-o"/>
                                </div>
                                <span class="card-label mb-0">Pending</span>
                            </div>
                            <div class="card-value text-danger">
                                <t t-esc="stats['pending_amount']"
                                   t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                            </div>
                            <div class="mt-2 pt-2 border-top border-light">
                                <div class="d-flex justify-content-between smaller">
                                    <span class="text-muted">Rent</span>
                                    <span class="fw-bold text-danger"><t t-esc="stats['pending_rent']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                                </div>
                                <div class="d-flex justify-content-between smaller">
                                    <span class="text-muted">Water</span>
                                    <span class="fw-bold text-info"><t t-esc="stats['pending_water']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Agreements Section -->
                <div class="section-title d-flex justify-content-between align-items-center mb-3 animate-up"
                     style="animation-delay: 0.2s;">
                    <h6 class="mb-0 fw-bold">Recent Agreements</h6>
                    <a href="/villa/mobile/agreements" class="small text-primary text-decoration-none fw-bold">View
                        All
                    </a>
                </div>

                <t t-foreach="agreements" t-as="agreement">
                    <div class="mobile-card animate-up" style="animation-delay: 0.3s;">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-3 rounded-4 me-3 text-primary">
                                    <i class="fa fa-building-o fa-lg"/>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">
                                        <t t-esc="agreement.villa_id.name"/>
                                    </h6>
                                    <p class="text-muted small mb-0">
                                        <t t-esc="agreement.partner_id.name"/>
                                    </p>
                                </div>
                            </div>
                            <span t-attf-class="badge #{'bg-success-light' if agreement.state == 'running' else 'bg-warning-light'}">
                                <t t-esc="agreement.state"/>
                            </span>
                        </div>
                        <div class="row g-2 pt-2 border-top">
                            <div class="col-4">
                                <p class="card-label mb-0">Rent</p>
                                <span class="small fw-bold">
                                    <t t-esc="agreement.monthly_rent"/>
                                </span>
                            </div>
                            <div class="col-4">
                                <p class="card-label mb-0">Due</p>
                                <span class="small fw-bold text-danger">
                                    <t t-esc="agreement.pending_amount"/>
                                </span>
                            </div>
                            <div class="col-4 text-end">
                                <a t-att-href="'/villa/mobile/agreement/%s' % agreement.id"
                                   class="btn btn-link p-0 text-primary fw-bold small text-decoration-none">Details
                                    <i class="fa fa-chevron-right ms-1 small"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Floating Action Button -->
            <a href="/villa/mobile/agreement/new" class="fab">
                <i class="fa fa-plus"/>
            </a>
        </t>
    </template>

    <!-- Mobile Agreement Detail -->
    <template id="villa_mobile_agreement_detail" name="Agreement Detail">
        <t t-call="kpm_villa.villa_mobile_layout">
            <div class="app-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <a href="/villa/mobile/dashboard" class="text-white me-3">
                        <i class="fa fa-chevron-left"/>
                    </a>
                    <h4 class="mb-0 fw-bold">Agreement Details</h4>
                </div>
                <a t-att-href="'/villa/mobile/agreement/%s/edit' % agreement.id"
                   class="text-white bg-white bg-opacity-25 rounded-3 px-3 py-2 text-decoration-none small fw-bold border border-white border-opacity-25">
                    <i class="fa fa-edit me-1"/>
                    Edit
                </a>
            </div>

            <div class="container pb-5">
                <!-- Status & Title -->
                <div class="mobile-card animate-up">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span t-attf-class="badge #{'bg-success-light' if agreement.state == 'running' else 'bg-warning-light'}">
                            <t t-esc="agreement.state"/>
                        </span>
                        <span class="text-muted small fw-bold">REF:
                            <t t-esc="agreement.name"/>
                        </span>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary bg-opacity-10 p-4 rounded-4 me-3 text-primary">
                            <i class="fa fa-building-o fa-2x"/>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">
                                <t t-esc="agreement.villa_id.name"/>
                            </h5>
                            <p class="text-muted mb-0">
                                <t t-esc="agreement.partner_id.name"/>
                            </p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="bg-light p-3 rounded-4">
                                <span class="card-label">Start Date</span>
                                <span class="fw-bold d-block">
                                    <t t-esc="agreement.start_date"/>
                                </span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light p-3 rounded-4">
                                <span class="card-label">End Date</span>
                                <span class="fw-bold d-block">
                                    <t t-esc="agreement.end_date"/>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Financials -->
                <div class="mobile-card animate-up" style="animation-delay: 0.1s;">
                    <h6 class="fw-bold mb-3 d-flex align-items-center">
                        <i class="fa fa-money me-2 text-success"/>
                        Financial Overview
                    </h6>
                    <div class="list-item-mobile">
                        <span class="text-muted">Monthly Rent</span>
                        <span class="fw-bold text-primary">
                            <t t-esc="agreement.monthly_rent"
                               t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Total Paid</span>
                        <span class="fw-bold text-success">
                            <t t-esc="agreement.total_paid"
                               t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </span>
                    </div>
                    <div class="list-item-mobile">
                        <span class="text-muted">Pending Amount</span>
                        <span class="fw-bold text-danger">
                            <t t-esc="agreement.pending_amount"
                               t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </span>
                    </div>

                </div>

                <!-- Payment History -->
                <!--                    <div class="mobile-card animate-up" style="animation-delay: 0.2s;">-->
                <!--                        <h6 class="fw-bold mb-3 d-flex align-items-center">-->
                <!--                            <i class="fa fa-history me-2 text-info"/>-->
                <!--                            Payment History-->
                <!--                        </h6>-->
                <!--                        <t t-if="agreement.payment_line_ids">-->
                <!--                            <t t-foreach="agreement.payment_line_ids" t-as="pay">-->
                <!--                                <div class="list-item-mobile">-->
                <!--                                    <div>-->
                <!--                                        <p class="mb-0 small fw-bold">-->
                <!--                                            <t t-esc="pay.month"/>-->
                <!--                                        </p>-->
                <!--                                        <p class="mb-0 text-muted smaller">-->
                <!--                                            <t t-esc="pay.payment_date"/>-->
                <!--                                        </p>-->
                <!--                                    </div>-->
                <!--                                    <div class="text-end">-->
                <!--                                        <p class="mb-0 fw-bold text-success">+-->
                <!--                                            <t t-esc="pay.paid_amount"/>-->
                <!--                                        </p>-->
                <!--                                        <t t-if="pay.pending_amount > 0">-->
                <!--                                            <p class="mb-0 text-danger smaller">Due:-->
                <!--                                                <t t-esc="pay.pending_amount"/>-->
                <!--                                            </p>-->
                <!--                                        </t>-->
                <!--                                    </div>-->
                <!--                                </div>-->
                <!--                            </t>-->
                <!--                        </t>-->
                <!--                        <t t-else="">-->
                <!--                            <p class="text-center text-muted py-3 mb-0 small">No payment history yet.</p>-->
                <!--                        </t>-->
                <!--                        <div class="pt-3 mt-3 border-top">-->
                <!--                            <button type="button" class="btn btn-success w-100 rounded-pill py-3 fw-bold border-0"-->
                <!--                                    data-bs-toggle="modal" data-bs-target="#addPaymentModal">-->
                <!--                                <i class="fa fa-plus-circle me-1"/>-->
                <!--                                Add Payment-->
                <!--                            </button>-->
                <!--                        </div>-->
                <!--                    </div>-->

                <div class="mobile-card animate-up" style="animation-delay: 0.2s;">
                    <h6 class="fw-bold mb-3 d-flex align-items-center">
                        <i class="fa fa-history me-2 text-info"/>
                        Payment History
                    </h6>

                    <t t-if="agreement.payment_line_ids">

                        <t t-foreach="agreement.payment_line_ids" t-as="pay">

                            <!-- ROW -->
                            <div class="py-3 border-bottom">

                                <div class="d-flex justify-content-between align-items-start">

                                    <!-- LEFT -->
                                    <div class="pe-2">

                                        <div class="d-flex flex-column">

                                            <!-- Month -->
                                            <span class="small fw-bold text-dark">
                                                <t t-esc="dict(pay._fields['month'].selection).get(pay.month)"/>
                                            </span>

                                            <!-- Paid Amount -->
                                            <span class="small fw-bold text-dark">
                                                Paid:
                                                <t t-esc="pay.paid_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                            </span>

                                            <!-- Payment Date -->
                                            <span class="text-muted smaller">
                                                <t t-esc="pay.payment_date"/>
                                            </span>

                                        </div>

                                    </div>

                                    <!-- RIGHT -->
                                    <div class="text-end">

                                        <!-- Due -->
                                        <t t-if="pay.pending_amount > 0">

                                            <div class="d-flex align-items-center justify-content-end gap-2">

                                                <span class="smaller fw-bold text-danger">
                                                    Due:
                                                    <t t-esc="pay.pending_amount" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                                </span>

                                                <!-- Add Button -->
                                                <button type="button"
                                                        class="btn btn-success btn-sm rounded-circle d-flex align-items-center justify-content-center btn-add-due-payment"
                                                        style="width:32px;height:32px;"
                                                        t-att-data-payment-id="pay.id"
                                                        t-att-data-payment-month="pay.month"
                                                        t-att-data-payment-rent="pay.rent_amount"
                                                        t-att-data-payment-due="pay.pending_amount"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#addPaymentModal">

                                                    <i class="fa fa-plus"/>

                                                </button>

                                            </div>

                                        </t>

                                        <!-- Fully Paid -->
                                        <t t-else="">
                                            <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill"
                                                 style="
                                background: linear-gradient(135deg,#e8fff1,#d9fbe8);
                                color:#198754;
                                font-size:12px;
                                font-weight:700;
                                box-shadow:0 2px 8px rgba(25,135,84,0.12);
                             ">

                                                <i class="fa fa-check-circle"/>

                                                Fully Paid

                                            </div>
                                        </t>

                                    </div>

                                </div>

                            </div>

                        </t>

                    </t>

                    <t t-else="">
                        <p class="text-center text-muted py-3 mb-0 small">
                            No payment history yet.
                        </p>
                    </t>

                    <!-- Main Add Payment Button -->
                    <div class="pt-3 mt-3 border-top">

                        <button type="button"
                                class="btn btn-success w-100 rounded-pill py-3 fw-bold border-0 btn-add-new-payment"
                                t-att-data-payment-month="current_month"
                                t-att-data-payment-rent="agreement.monthly_rent"
                                data-bs-toggle="modal"
                                data-bs-target="#addPaymentModal">

                            <i class="fa fa-plus-circle me-1"/>
                            Add Payment

                        </button>

                    </div>

                </div>

                <!-- Water Bills -->
                <div class="mobile-card animate-up" style="animation-delay: 0.3s;">
                    <h6 class="fw-bold mb-3 d-flex align-items-center">
                        <i class="fa fa-tint me-2 text-info"/>
                        Water Bill Splits
                    </h6>
                    <t t-if="agreement.water_bill_line_ids">
                        <t t-foreach="agreement.water_bill_line_ids" t-as="water">

                            <div class="py-3 border-bottom">

                                <div class="d-flex justify-content-between align-items-start">

                                    <!-- LEFT -->
                                    <div class="pe-2">

                                        <!-- Name + Total -->
                                        <div class="d-flex flex-column">

                                            <!-- First Line -->
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <span class="small fw-bold text-dark">
                                                    <t t-esc="water.water_bill_id.name"/>
                                                </span>


                                            </div>

                                            <!-- Second Line -->
                                            <span class="small fw-bold text-dark">
                                                Total:
                                                <t t-esc="water.amount"
                                                   t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                                            </span>

                                        </div>

                                    </div>

                                    <!-- RIGHT -->
                                    <div class="text-end">

                                        <!-- Paid -->
                                        <div class="smaller text-muted mb-1">

                                            Paid:
                                            <t t-esc="water.paid_amount"
                                               t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>

                                        </div>

                                        <!-- Due -->
                                        <t t-if="water.due_amount > 0">

                                            <div class="d-flex align-items-center justify-content-end gap-2">

                                                <span class="smaller fw-bold text-danger">

                                                    Due:
                                                    <t t-esc="water.due_amount"
                                                       t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>

                                                </span>

                                                <button type="button"
                                                        class="btn btn-info btn-sm rounded-circle d-flex align-items-center justify-content-center btn-add-water-payment"
                                                        style="width:32px;height:32px;"
                                                        t-att-data-water-line-id="water.id"
                                                        t-att-data-water-due="water.due_amount"
                                                        t-att-data-water-name="water.water_bill_id.name"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#addWaterPaymentModal">

                                                    <i class="fa fa-plus"/>

                                                </button>

                                            </div>

                                        </t>

                                        <!-- Fully Paid -->
                                        <t t-else="">
                                            <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill"
                                                 style="
            background: linear-gradient(135deg,#e8fff1,#d9fbe8);
            color:#198754;
            font-size:12px;
            font-weight:700;
            box-shadow:0 2px 8px rgba(25,135,84,0.12);
         ">

                                                <i class="fa fa-check-circle"/>

                                                Fully Paid

                                            </div>
                                        </t>

                                    </div>

                                </div>

                            </div>

                        </t>
                    </t>
                    <t t-else="">
                        <p class="text-center text-muted py-3 mb-0 small">No water bills recorded.</p>
                    </t>
                </div>
            </div>

            <div class="modal fade" id="addWaterPaymentModal" tabindex="-1" aria-labelledby="addWaterPaymentModalLabel"
                 aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-sm mx-3 mx-sm-auto">
                    <div class="modal-content border-0 overflow-hidden" style="border-radius: 28px; box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);">
                        <form t-att-action="'/villa/mobile/agreement/%s/water/payment/save' % agreement.id"
                              method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="water_line_id" id="water_line_id"/>
                            <div class="modal-header border-0 text-white align-items-start" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%); padding: 22px 22px 18px;">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center me-3" style="width:44px;height:44px;">
                                        <i class="fa fa-tint"/>
                                    </div>
                                    <div>
                                        <h5 class="modal-title fw-bold mb-0" id="addWaterPaymentModalLabel">Pay Water Bill</h5>
                                        <span class="small opacity-75">Record a partial or full payment</span>
                                    </div>
                                </div>
                                <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal" aria-label="Close"/>
                            </div>
                            <div class="modal-body p-4">
                                <div class="rounded-4 p-3 mb-3" style="background: rgba(14, 165, 233, 0.10); border: 1px solid rgba(14, 165, 233, 0.14);">
                                    <span class="card-label d-block mb-1">Selected Bill</span>
                                    <p class="fw-bold text-info mb-0" id="water_payment_note"></p>
                                </div>
                                <div class="mb-0">
                                    <label class="card-label">Payment Amount</label>
                                    <div class="input-group rounded-4 overflow-hidden bg-light">
                                        <span class="input-group-text border-0 bg-light text-muted">
                                            <t t-esc="res_company.currency_id.symbol"/>
                                        </span>
                                        <input type="number" name="water_payment_amount" id="water_payment_amount"
                                               class="form-control border-0 bg-light py-3 fw-bold" step="0.01" min="0"
                                               placeholder="0.00" required="required"/>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0 px-4 pb-4 d-grid gap-2">
                                <button type="submit" class="btn btn-info rounded-pill py-3 fw-bold text-white border-0" style="background: linear-gradient(135deg, var(--app-info) 0%, #38bdf8 100%);">Save Payment</button>
                                <button type="button" class="btn btn-light rounded-pill py-2" data-bs-dismiss="modal">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="addPaymentModal" tabindex="-1" aria-labelledby="addPaymentModalLabel"
                 aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content rounded-4 border-0">
                        <form t-att-action="'/villa/mobile/agreement/%s/payment/save' % agreement.id" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="payment_id" id="payment_id"/>
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold" id="addPaymentModalLabel">Add Payment</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"/>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="card-label">Payment Date</label>
                                    <input type="date" name="payment_date" class="form-control border-0 bg-light"
                                           t-att-value="today" required="required"/>
                                </div>
                                <div class="mb-3">
                                    <label class="card-label">Month</label>
                                    <select name="month" class="form-select border-0 bg-light" required="required">
                                        <option value="01" t-att-selected="current_month == '01'">January</option>
                                        <option value="02" t-att-selected="current_month == '02'">February</option>
                                        <option value="03" t-att-selected="current_month == '03'">March</option>
                                        <option value="04" t-att-selected="current_month == '04'">April</option>
                                        <option value="05" t-att-selected="current_month == '05'">May</option>
                                        <option value="06" t-att-selected="current_month == '06'">June</option>
                                        <option value="07" t-att-selected="current_month == '07'">July</option>
                                        <option value="08" t-att-selected="current_month == '08'">August</option>
                                        <option value="09" t-att-selected="current_month == '09'">September</option>
                                        <option value="10" t-att-selected="current_month == '10'">October</option>
                                        <option value="11" t-att-selected="current_month == '11'">November</option>
                                        <option value="12" t-att-selected="current_month == '12'">December</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="card-label">Rent Amount</label>
                                    <input type="number" name="rent_amount" class="form-control border-0 bg-light"
                                           t-att-value="agreement.monthly_rent" step="0.01" min="0"
                                           required="required"/>
                                </div>
                                <div class="mb-3">
                                    <label class="card-label" id="paid_amount_label">Paid Amount</label>
                                    <input type="number" name="paid_amount" id="paid_amount"
                                           class="form-control border-0 bg-light"
                                           step="0.01" min="0" required="required"/>
                                </div>
                                <div class="mb-3">
                                    <label class="card-label">Payment Method</label>
                                    <select name="payment_method" class="form-select border-0 bg-light">
                                        <option value="cash">Cash</option>
                                        <option value="bank">Bank Transfer</option>
                                        <option value="cheque">Cheque</option>
                                        <option value="online">Online</option>
                                    </select>
                                </div>
                                <div class="mb-0">
                                    <label class="card-label">Remarks</label>
                                    <textarea name="remarks" class="form-control border-0 bg-light" rows="2"
                                              placeholder="Optional note"></textarea>
                                </div>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">
                                    Cancel
                                </button>
                                <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Save Payment
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
