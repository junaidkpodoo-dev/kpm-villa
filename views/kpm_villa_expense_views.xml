<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpm_villa_expense_tree" model="ir.ui.view">
        <field name="name">kpm.villa.expense.tree</field>
        <field name="model">kpm.villa.expense</field>
        <field name="arch" type="xml">
            <list string="Expenses">
                <field name="name"/>
                <field name="expense_date"/>
                <field name="expense_type"/>
                <field name="villa_id"/>
                <field name="amount" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="view_kpm_villa_expense_form" model="ir.ui.view">
        <field name="name">kpm.villa.expense.form</field>
        <field name="model">kpm.villa.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="expense_date"/>
                            <field name="expense_type"/>
                        </group>
                        <group>
                            <field name="villa_id"/>
                            <field name="amount"/>
                            <field name="vendor_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kpm_villa_expense_pivot" model="ir.ui.view">
        <field name="name">kpm.villa.expense.pivot</field>
        <field name="model">kpm.villa.expense</field>
        <field name="arch" type="xml">
            <pivot string="Expense Analysis">
                <field name="expense_type" type="row"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_kpm_villa_expense_graph" model="ir.ui.view">
        <field name="name">kpm.villa.expense.graph</field>
        <field name="model">kpm.villa.expense</field>
        <field name="arch" type="xml">
            <graph string="Expense Analysis">
                <field name="expense_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_kpm_villa_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">kpm.villa.expense</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>
</odoo>
